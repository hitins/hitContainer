FROM debian:trixie-slim

RUN set -ex && apt -y update && apt -y dist-upgrade \
    && apt -y install dialog readline-common \
    && apt -y install wget bridge-utils net-tools liblzo2-2 libmariadb3 libnl-genl-3-200 libpcap0.8t64 libsasl2-2 iproute2 sqlite3 iptables dmidecode \
    && apt -y install python3-netaddr python3-cffi python3-ldap3 python3-constantly python3-hyperlink python3-automat python3-defusedxml python3-hamcrest python3-zope python3-service-identity python3-xmlsec python3-packaging python3-onelogin-saml2 python3-tomli python3-six python3-arrow \
    && wget -O openvpnclient.deb https://openvpn.net/downloads/openvpn-as-bundled-clients-latest.deb \
    && wget -O openvpnas.deb https://openvpn.net/downloads/openvpn-as-latest-debian13.amd_64.deb \
    && dpkg -i openvpnclient.deb && dpkg -i openvpnas.deb && rm openvpnas.deb openvpnclient.deb \
    && apt -y clean all 

STOPSIGNAL SIGINT
ENTRYPOINT ["/usr/local/openvpn_as/scripts/openvpnas"]
CMD ["--nodaemon", "--logfile=/var/log/openvpnas.log"]
